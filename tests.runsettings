<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <!-- This environment variable works in both dotnet test and VS Test Explorer -->
      <HEADED>1</HEADED>
    </EnvironmentVariables>
  </RunConfiguration>
    
  <Playwright>
    <BrowserName>chromium</BrowserName>
    <LaunchOptions>
      <!-- This SlowMo setting works with 'dotnet test' but is IGNORED in VS Test Explorer -->
      <SlowMo>2000</SlowMo>
    </LaunchOptions>
  </Playwright>
</RunSettings>
